{
  "name": "steam-review-editor",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.8.2"
  },
  "scripts": {
    "start": "vite",
    "build": "tsx && vite build",
    "preview": "vite preview",
    "test": "vitest"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "env": {
      "browser": true,
      "mocha": true,
      "chai": true
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@tiptap/extension-document": "^2.11.7",
    "@tiptap/extension-paragraph": "^2.11.7",
    "@tiptap/extension-text": "^2.11.7",
    "@tiptap/react": "^2.11.7",
    "@vitejs/plugin-react": "4.3.4",
    "axios": "^1.8.4",
    "classnames": "^2.5.1",
    "editorjs-html": "^4.0.5",
    "is-image": "^4.0.0",
    "is-url": "^1.2.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-modal": "^3.16.3",
    "react-toastify": "^11.0.5",
    "sass": "^1.86.3",
    "typescript": "^5.8.3",
    "vite": "^6.2.5",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "vitest": "^3.1.1"
  }
}
